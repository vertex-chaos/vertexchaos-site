---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import { site } from "../config/site";

interface Props {
  title?: string;
  description?: string;
  noHeader?: boolean;
  jsonLd?: object;
}

const {
  title = "vertex_chaos",
  description = site.subhead,
  noHeader = false,
  jsonLd,
} = Astro.props;

const canonical = `https://${site.domain}${Astro.url.pathname}`;
const ogTitle = title.replace(/\s*\|.*$/, "").trim();

// Default LocalBusiness JSON-LD for every page
const defaultJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Vertex Chaos",
  "url": `https://${site.domain}`,
  "email": site.email,
  "description": site.subhead,
  "areaServed": "US",
  "founder": {
    "@type": "Person",
    "name": "Jose Valdes",
    "sameAs": [site.links.linkedin, site.links.github],
    "knowsLanguage": ["en", "es"],
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "IT Infrastructure & Automation Services",
  },
};

const structuredData = JSON.stringify(jsonLd ?? defaultJsonLd);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Vertex Chaos" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={structuredData} />

    <!-- Cloudflare Web Analytics injected automatically via Cloudflare proxy -->
  </head>

  <body>
    {!noHeader && <SiteHeader />}
    <main class="mx-auto max-w-6xl px-6 py-10">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-20 border-t border-slate-200 bg-slate-900 text-slate-400">
      <div class="mx-auto max-w-6xl px-6 py-12">
        <div class="flex flex-wrap items-start justify-between gap-10">
          <div>
            <div class="flex items-center gap-3 mb-3">
              <span class="grid h-8 w-8 place-items-center rounded-md bg-blue-600 text-xs font-bold text-white">vc</span>
              <span class="text-sm font-semibold text-white">vertex_chaos</span>
            </div>
            <p class="text-xs max-w-xs leading-relaxed">IT infrastructure and automation for small and mid-sized businesses. U.S.-based, remote.</p>
          </div>
          <div class="flex flex-wrap gap-12 text-sm">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-3">Services</p>
              <div class="flex flex-col gap-2">
                <a class="no-underline hover:text-white transition-colors" href="/services">All packages</a>
                <a class="no-underline hover:text-white transition-colors" href="/contact">Get a quote</a>
              </div>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-3">Work</p>
              <div class="flex flex-col gap-2">
                <a class="no-underline hover:text-white transition-colors" href="/work">Case studies</a>
                <a class="no-underline hover:text-white transition-colors" href="/blog">Blog</a>
              </div>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-3">Connect</p>
              <div class="flex flex-col gap-2">
                <a class="no-underline hover:text-white transition-colors" href={site.links.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
                <a class="no-underline hover:text-white transition-colors" href="/about">About</a>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-10 border-t border-slate-800 pt-6 flex flex-wrap items-center justify-between gap-4 text-xs">
          <span>© {new Date().getFullYear()} Vertex Chaos LLC</span>
          <a class="no-underline hover:text-white transition-colors" href="/privacy">Privacy</a>
        </div>
      </div>
    </footer>
  </body>
</html>
