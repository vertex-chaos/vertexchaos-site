---
import { site, mailtoLink } from "@/config/site";
const nav = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/work", label: "Work" },
  { href: "/docs/", label: "Docs" },
  { href: "/resume", label: "Resume" },
  { href: "/upwork", label: "Upwork" },
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b" style="border-color: var(--color-app-border); backdrop-filter: blur(10px); background: color-mix(in oklab, var(--color-app-bg) 75%, transparent);">
  <div class="vc-container flex items-center justify-between py-4">
    <a href="/" class="flex items-center gap-3">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl font-bold"
        style="background: color-mix(in oklab, var(--color-vertex-500) 28%, transparent); border: 1px solid var(--color-app-border);"
        aria-hidden="true">V</span>
      <div class="leading-tight">
        <div class="text-sm font-semibold">{site.name}</div>
        <div class="text-xs" style="color: var(--color-app-muted);">{site.location}</div>
      </div>
    </a>

    <nav class="hidden items-center gap-6 md:flex">
      {nav.map((n) => (
        <a href={n.href} class="text-sm" style="color: var(--color-app-muted);">
          {n.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a class="vc-btn vc-btn-primary" href={mailtoLink}>Contact for quote</a>
    </div>
  </div>

  <!-- Mobile nav -->
  <div class="vc-container md:hidden pb-3">
    <div class="flex flex-wrap gap-3">
      {nav.map((n) => (
        <a class="vc-pill" href={n.href}>{n.label}</a>
      ))}
    </div>
  </div>
</header>
