---
import { site } from "../config/site";
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur-sm">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">

    <a href="/" class="flex items-center gap-3 no-underline group">
      <span class="grid h-9 w-9 place-items-center rounded-lg bg-slate-900 text-xs font-bold text-white tracking-wider group-hover:bg-blue-600 transition-colors">
        vc
      </span>
      <span class="text-sm font-semibold text-slate-900 tracking-tight">{site.brand}</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {site.nav.map((n) => (
        <a
          class="rounded-lg px-3 py-2 text-sm text-slate-600 no-underline hover:bg-slate-100 hover:text-slate-900 transition-colors"
          href={n.href}
        >
          {n.label}
        </a>
      ))}
    </nav>

    <a
      href={site.links.contact}
      class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white no-underline hover:bg-blue-700 transition-colors shadow-sm"
    >
      Contact
    </a>
  </div>
</header>
