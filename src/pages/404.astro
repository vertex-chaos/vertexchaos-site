---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/config/site";
---

<BaseLayout title={`${site.name} | Not found`} noindex={true}>
  <section class="vc-container pt-14 pb-20">
    <div class="vc-card p-8 md:p-10">
      <h1 class="text-2xl font-semibold">404</h1>
      <p class="mt-2 text-sm" style="color: var(--color-app-muted);">
        That page doesn’t exist. Probably for the best.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="vc-btn vc-btn-primary" href="/">Home</a>
        <a class="vc-btn" href="/services">Services</a>
        <a class="vc-btn" href="/contact">Contact</a>
      </div>
    </div>
  </section>
</BaseLayout>
