---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../config/site";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const posts = allPosts
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout
  title={`Blog | ${site.brand}`}
  description="Practical notes on infrastructure, automation, and AI workflows from 22 years of ops work."
>

  <div>
    <p class="text-sm text-slate-500">blog</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-slate-900">Blog</h1>
    <p class="mt-4 max-w-2xl text-slate-600">
      Practical notes on Active Directory, PowerShell, networking, and AI-powered ops. No fluff.
    </p>
  </div>

  <div class="mt-12 grid gap-6">
    {posts.map((post) => {
      const d = post.data;
      const href = `/blog/${post.slug}`;
      const dateStr = new Date(d.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
      return (
        <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
              <time class="text-xs text-slate-400" datetime={d.date}>{dateStr}</time>
              <h2 class="mt-1">
                <a href={href} class="text-lg font-semibold text-slate-900 hover:underline no-underline">
                  {d.title}
                </a>
              </h2>
              <p class="mt-2 text-sm text-slate-600">{d.summary}</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {d.tags.map((t: string) => (
                  <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs text-slate-600">{t}</span>
                ))}
              </div>
            </div>
            <a href={href} class="shrink-0 text-slate-400 hover:text-slate-700 text-lg no-underline" aria-label="Read post">↗</a>
          </div>
        </article>
      );
    })}
  </div>

  {posts.length === 0 && (
    <p class="mt-12 text-slate-500">No posts yet. Check back soon.</p>
  )}

</BaseLayout>
