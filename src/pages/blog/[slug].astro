---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../config/site";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts
    .filter(p => !p.data.draft)
    .map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const d = post.data;
const dateStr = new Date(d.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
const canonical = `https://${site.domain}/blog/${post.slug}`;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": d.title,
  "description": d.summary,
  "datePublished": d.date,
  "author": {
    "@type": "Person",
    "name": "Jose Valdes",
    "url": `https://${site.domain}/about`,
  },
  "publisher": {
    "@type": "Organization",
    "name": "Vertex Chaos",
    "url": `https://${site.domain}`,
  },
  "url": canonical,
};
---

<BaseLayout
  title={`${d.title} | ${site.brand}`}
  description={d.summary}
  jsonLd={articleJsonLd}
>

  <article class="mx-auto max-w-2xl">

    <div class="mb-8">
      <a href="/blog" class="text-sm text-slate-500 hover:text-slate-900 no-underline">← Blog</a>
    </div>

    <header class="mb-10">
      <div class="flex flex-wrap gap-2 mb-4">
        {d.tags.map((t: string) => (
          <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs text-slate-600">{t}</span>
        ))}
      </div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 leading-tight">{d.title}</h1>
      <time class="mt-3 block text-sm text-slate-400" datetime={d.date}>{dateStr}</time>
    </header>

    <div class="blog-content">
      <Content />
    </div>

    <footer class="mt-16 border-t border-slate-200 pt-8">
      <div class="rounded-2xl bg-slate-50 border border-slate-200 p-6">
        <p class="text-sm font-semibold text-slate-900">Got a related problem?</p>
        <p class="mt-1 text-sm text-slate-600">
          I do fixed-price infrastructure and automation work. Describe what you're dealing with and I'll tell you if it fits a package.
        </p>
        <a href="/contact" class="mt-4 inline-block rounded-xl bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white no-underline hover:bg-slate-800">
          Get in touch
        </a>
      </div>
    </footer>

  </article>

</BaseLayout>
