---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/config/site";
---

<BaseLayout title={`${site.name} | Legal`} description="Legal and privacy (mockup boilerplate, public-safe).">
  <section class="vc-container pt-14 pb-20">
    <h1 class="text-2xl font-semibold">Legal</h1>
    <p class="mt-2 text-sm" style="color: var(--color-app-muted);">
      This page is intentionally plain. Humans love lawsuits; software loves clarity.
    </p>

    <div class="mt-8 grid gap-6">
      <div class="vc-card p-7 md:p-8">
        <h2 class="text-lg font-semibold">Business identity</h2>
        <p class="mt-2 text-sm" style="color: var(--color-app-muted);">
          Legal entity: <span class="font-semibold">{site.legalName}</span>
        </p>
        <p class="mt-2 text-sm" style="color: var(--color-app-muted);">
          This site is a portfolio and information resource. Content is provided "as-is" and may be updated without notice.
        </p>
      </div>

      <div class="vc-card p-7 md:p-8">
        <h2 class="text-lg font-semibold">Privacy (mockup)</h2>
        <ul class="mt-3 space-y-2 text-sm" style="color: var(--color-app-muted);">
          <li>• No tracking pixels, no weird ad networks, and no selling of personal data.</li>
          <li>• Server logs (if any) are used for basic operational purposes and security.</li>
          <li>• Email inquiries are used only to respond to your request.</li>
          <li>• If you want something removed, request it via email and it will be reviewed.</li>
        </ul>
      </div>

      <div class="vc-card p-7 md:p-8">
        <h2 class="text-lg font-semibold">Terms (mockup)</h2>
        <ul class="mt-3 space-y-2 text-sm" style="color: var(--color-app-muted);">
          <li>• Portfolio summaries are intentionally public-safe: no client names, employer names, or identifiable internal details.</li>
          <li>• Any engagement terms, scope, and pricing are defined in writing per project.</li>
          <li>• The "Contact for quote" email link does not create a contract or obligation.</li>
          <li>• If you send sensitive data, you are responsible for redacting it first. I will not store secrets outside a project’s agreed tooling.</li>
        </ul>
      </div>

      <div class="vc-card p-7 md:p-8">
        <h2 class="text-lg font-semibold">Disclaimer</h2>
        <p class="mt-2 text-sm" style="color: var(--color-app-muted);">
          This is not legal advice. For actual legal advice, hire an attorney. Shocking, I know.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
