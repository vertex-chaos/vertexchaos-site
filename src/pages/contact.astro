---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config/site";

const FORMSPREE_ID = "mqevnego";
---

<BaseLayout title="Contact | vertex_chaos" description="Get in touch with Vertex Chaos. Fixed-price IT infrastructure and AI automation services.">

  <div>
    <p class="text-sm text-slate-500">contact</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-slate-900">Get in touch</h1>
    <p class="mt-4 max-w-lg text-slate-600">
      Describe your environment and what is causing friction. I will respond within 4 hours on business days
      with whether it fits a package or needs a custom scope.
    </p>
  </div>

  <div class="mt-10 grid gap-10 lg:grid-cols-2">

    <!-- Form -->
    <form
      action={`https://formspree.io/f/${FORMSPREE_ID}`}
      method="POST"
      class="space-y-5"
    >
      <div>
        <label for="name" class="block text-sm font-medium text-slate-700">Name</label>
        <input
          id="name" name="name" type="text" required
          class="mt-1 block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 placeholder-slate-400 focus:border-slate-500 focus:outline-none"
          placeholder="Your name"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-slate-700">Email</label>
        <input
          id="email" name="email" type="email" required
          class="mt-1 block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 placeholder-slate-400 focus:border-slate-500 focus:outline-none"
          placeholder="you@company.com"
        />
      </div>

      <div>
        <label for="type" class="block text-sm font-medium text-slate-700">What do you need?</label>
        <select
          id="type" name="project_type"
          class="mt-1 block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 focus:border-slate-500 focus:outline-none"
        >
          <option value="">Select a category</option>
          <option value="ad-audit">AD Health Check / Audit</option>
          <option value="ad-cleanup">AD Cleanup Sprint</option>
          <option value="gpo-audit">GPO Audit</option>
          <option value="m365">M365 / Entra ID / Security</option>
          <option value="automation">PowerShell / Python Automation</option>
          <option value="ai-workflow">AI / n8n Workflow</option>
          <option value="retainer">Monthly Retainer</option>
          <option value="other">Something else</option>
        </select>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-slate-700">Brief description</label>
        <textarea
          id="message" name="message" rows="5" required
          class="mt-1 block w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 placeholder-slate-400 focus:border-slate-500 focus:outline-none resize-none"
          placeholder="What environment are you running? What is causing friction? Rough user/server count helps."
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full rounded-xl bg-slate-900 px-6 py-3 text-sm font-semibold text-white hover:bg-slate-800"
      >
        Send message
      </button>
    </form>

    <!-- Details -->
    <div class="space-y-6">
      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h2 class="text-base font-semibold text-slate-900">What to include</h2>
        <ul class="mt-4 space-y-2 text-sm text-slate-600">
          <li>→ What environment you are running (Windows, hybrid, cloud-only)</li>
          <li>→ Rough user count and server count</li>
          <li>→ What is causing the most friction right now</li>
          <li>→ Whether you have a deadline</li>
        </ul>
        <p class="mt-4 text-sm text-slate-500">No RFP, no intro call required. A few sentences is enough.</p>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h2 class="text-base font-semibold text-slate-900">Response time</h2>
        <p class="mt-2 text-sm text-slate-600">Within 4 hours on U.S. business days. Email works too:</p>
        <a href={site.links.email} class="mt-3 inline-block text-sm font-semibold text-slate-900 no-underline hover:underline">
          {site.email}
        </a>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h2 class="text-base font-semibold text-slate-900">Languages</h2>
        <p class="mt-2 text-sm text-slate-600">English and Spanish. Write in whichever is easier for you.</p>
      </div>
    </div>

  </div>

</BaseLayout>
