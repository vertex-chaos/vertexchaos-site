---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site, mailtoLink } from "@/config/site";
import { upwork } from "@/config/upwork";
---

<BaseLayout title={`${site.name} | Upwork materials`} description="Public-safe Upwork overview, headlines, specialized profiles, discovery questions, and project catalog tiers.">
  <section class="vc-container pt-14">
    <h1 class="text-2xl font-semibold">Upwork materials</h1>
    <p class="mt-2 text-sm" style="color: var(--color-app-muted);">
      Written for conversion, but public-safe: no client names, employer names, or identifiable details.
    </p>

    <div class="mt-8 grid gap-6">
      <div class="vc-card p-7 md:p-8">
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
          <div>
            <div class="text-sm font-semibold">{upwork.title}</div>
            <div class="mt-1 text-sm" style="color: var(--color-app-muted);">{upwork.location}</div>
          </div>
          <div class="flex flex-wrap gap-2 md:justify-end">
            {upwork.stats.map((s) => <span class="vc-pill">{s.label}: {s.value}</span>)}
            <span class="vc-pill">{upwork.rateNote}</span>
          </div>
        </div>

        <div class="mt-6 flex flex-wrap gap-3">
          <a class="vc-btn vc-btn-primary" href={mailtoLink}>Contact for quote</a>
          <a class="vc-btn" href="/contact">Discovery questions</a>
        </div>
      </div>

      <div class="vc-card p-7 md:p-8">
        <h2 class="text-lg font-semibold">A) Overview</h2>

        <div class="mt-4 grid gap-5 md:grid-cols-2">
          <div class="rounded-2xl border p-5" style="border-color: var(--color-app-border); background: color-mix(in oklab, white 2.5%, transparent);">
            <div class="text-sm font-semibold">Short (120–180 words)</div>
            <p class="mt-3 text-sm whitespace-pre-line" style="color: var(--color-app-muted);">{upwork.overviewShort}</p>
          </div>
          <div class="rounded-2xl border p-5" style="border-color: var(--color-app-border); background: color-mix(in oklab, white 2.5%, transparent);">
            <div class="text-sm font-semibold">Long (250–400 words)</div>
            <p class="mt-3 text-sm whitespace-pre-line" style="color: var(--color-app-muted);">{upwork.overviewLong}</p>
          </div>
        </div>
      </div>

      <div class="vc-card p-7 md:p-8">
        <h2 class="text-lg font-semibold">B) Headline options</h2>
        <p class="mt-2 text-sm" style="color: var(--color-app-muted);">
          Keyword-heavy without sounding like a used-car listing.
        </p>
        <ol class="mt-4 space-y-2 text-sm" style="color: var(--color-app-muted);">
          {upwork.headlines.map((h, i) => <li>{i + 1}. {h}</li>)}
        </ol>
      </div>

      <div class="vc-card p-7 md:p-8">
        <h2 class="text-lg font-semibold">C) Specialized profiles</h2>
        <div class="mt-4 grid gap-5 md:grid-cols-3">
          {upwork.specialized.map((s) => (
            <div class="rounded-2xl border p-5" style="border-color: var(--color-app-border); background: color-mix(in oklab, white 2.5%, transparent);">
              <div class="text-sm font-semibold">{s.name}</div>
              <p class="mt-2 text-sm" style="color: var(--color-app-muted);">{s.text}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="vc-card p-7 md:p-8">
        <h2 class="text-lg font-semibold">E) Discovery questions</h2>
        <p class="mt-2 text-sm" style="color: var(--color-app-muted);">
          Use these before quoting so scope doesn’t drift into chaos.
        </p>
        <ul class="mt-4 space-y-2 text-sm" style="color: var(--color-app-muted);">
          {upwork.discoveryQuestions.map((q) => <li>• {q}</li>)}
        </ul>
      </div>

      <div class="vc-card p-7 md:p-8">
        <h2 class="text-lg font-semibold">F) Project Catalog offerings</h2>
        <div class="mt-6 grid gap-6">
          {upwork.catalog.map((c) => (
            <div class="rounded-2xl border p-6" style="border-color: var(--color-app-border); background: color-mix(in oklab, white 2.5%, transparent);">
              <div class="text-base font-semibold">{c.title}</div>
              <div class="mt-4 grid gap-4 md:grid-cols-3">
                {c.tiers.map((t) => (
                  <div class="vc-card p-5">
                    <div class="text-sm font-semibold">{t.name}</div>
                    <ul class="mt-3 space-y-2 text-sm" style="color: var(--color-app-muted);">
                      {t.scope.map((s) => <li>• {s}</li>)}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="vc-card p-7 md:p-8">
        <h2 class="text-lg font-semibold">Social proof (sanitized)</h2>
        <p class="mt-3 text-sm" style="color: var(--color-app-muted);">{upwork.socialProof}</p>
      </div>
    </div>
  </section>

  <section class="vc-container mt-14 pb-20">
    <div class="vc-card p-8 md:p-10">
      <h2 class="text-xl font-semibold">Want a proposal tailored to your job post?</h2>
      <p class="mt-2 text-sm" style="color: var(--color-app-muted);">
        Send the industry, pain, stack, constraints, deliverables, timeline, and success criteria.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="vc-btn vc-btn-primary" href={mailtoLink}>Contact for quote</a>
        <a class="vc-btn" href="/contact">Discovery questions</a>
      </div>
    </div>
  </section>
</BaseLayout>
