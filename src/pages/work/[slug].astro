---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site, mailtoLink } from "@/config/site";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("work");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${site.name} | ${entry.data.title}`} description={entry.data.excerpt}>
  <section class="vc-container pt-14">
    <div class="vc-card p-7 md:p-10">
      <p class="vc-pill">Public-safe case study</p>
      <h1 class="mt-3 text-2xl font-semibold">{entry.data.title}</h1>
      <p class="mt-2 text-sm" style="color: var(--color-app-muted);">{entry.data.excerpt}</p>

      <div class="mt-6 flex flex-wrap gap-2">
        {entry.data.stack.map((t) => <span class="vc-pill">{t}</span>)}
      </div>

      <div class="mt-8 vc-prose">
        <Content />
      </div>

      <hr class="my-10" />

      <div class="grid gap-6 md:grid-cols-2">
        <div>
          <div class="text-sm font-semibold">Outcomes</div>
          <ul class="mt-2 space-y-2 text-sm" style="color: var(--color-app-muted);">
            {entry.data.outcomes.map((o) => <li>• {o}</li>)}
          </ul>
        </div>

        <div>
          <div class="text-sm font-semibold">Next step</div>
          <p class="mt-2 text-sm" style="color: var(--color-app-muted);">
            If you want a similar result, send constraints and a definition of done.
          </p>
          <div class="mt-4 flex flex-wrap gap-3">
            <a class="vc-btn vc-btn-primary" href={mailtoLink}>Contact for quote</a>
            <a class="vc-btn" href="/contact">What to send</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="vc-container mt-10 pb-20">
    <a class="vc-link text-sm" href="/work">← Back to work</a>
  </section>
</BaseLayout>
