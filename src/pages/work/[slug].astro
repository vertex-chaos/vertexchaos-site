---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Tag from "../../components/Tag.astro";
import { site } from "../../config/site";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("case-studies");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data ?? {};
---

<BaseLayout title={`${d.title ?? "Work"} | ${site.brand}`} description={d.summary ?? site.subhead}>
  <div class="flex items-center gap-2 text-sm text-slate-500">
    <a class="no-underline hover:text-slate-900" href="/work/">Work</a>
    <span class="text-slate-300">/</span>
    <span>{d.title ?? entry.slug}</span>
  </div>

  <article class="prose prose-slate mt-8 max-w-none">
    <h1>{d.title ?? entry.slug}</h1>

    {d.summary && <p class="text-slate-600">{d.summary}</p>}

    <div class="mt-6 flex flex-wrap gap-2">
      {Array.isArray(d.tags) && d.tags.map((t) => <Tag label={t} />)}
    </div>

    <div class="mt-10">
      <Content />
    </div>

    <div class="mt-16 not-prose -mx-6 bg-slate-900 px-6 py-12 text-center text-white">
      <h2 class="text-2xl font-bold tracking-tight">Have a similar challenge?</h2>
      <p class="mt-3 text-slate-300">Describe your environment and the friction. I'll respond within 4 hours with a scope and price.</p>
      <a
        href={site.links.contact}
        class="mt-6 inline-block rounded-lg bg-blue-600 px-8 py-3 text-sm font-semibold text-white no-underline hover:bg-blue-500 transition-colors shadow-lg"
      >
        Get in touch →
      </a>
    </div>

    <div class="mt-8 flex items-center justify-between border-t border-slate-200 pt-6 text-sm">
      <a class="no-underline hover:underline" href="/work/">← Back to Work</a>
      <a class="no-underline hover:underline" href={site.githubOrgBase}>GitHub →</a>
    </div>
  </article>
</BaseLayout>