---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site, mailtoLink } from "@/config/site";
import { getCollection } from "astro:content";

const work = await getCollection("work");
---

<BaseLayout title={`${site.name} | Work`} description="Selected work (public-safe summaries).">
  <section class="vc-container pt-14">
    <h1 class="text-2xl font-semibold">Work</h1>
    <p class="mt-2 text-sm" style="color: var(--color-app-muted);">
      These are public-safe summaries. No client names, no employer names, no internal screenshots, and no identifiable details.
    </p>

    <div class="mt-8 grid gap-5 md:grid-cols-2">
      {work.map((w) => (
        <a class="vc-card block p-7" href={`/work/${w.slug}`}>
          <h2 class="text-base font-semibold">{w.data.title}</h2>
          <p class="mt-2 text-sm" style="color: var(--color-app-muted);">{w.data.excerpt}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {w.data.stack.map((t) => <span class="vc-pill">{t}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="vc-container mt-14 pb-20">
    <div class="vc-card p-8 md:p-10">
      <h2 class="text-xl font-semibold">Want a similar outcome?</h2>
      <p class="mt-2 text-sm" style="color: var(--color-app-muted);">
        Send constraints + success criteria. I’ll respond with a milestone plan.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="vc-btn vc-btn-primary" href={mailtoLink}>Contact for quote</a>
        <a class="vc-btn" href="/contact">What to send</a>
      </div>
    </div>
  </section>
</BaseLayout>
