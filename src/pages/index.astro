---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config/site";
import Card from "../components/Card.astro";
import Tag from "../components/Tag.astro";

const services = [
  {
    title: "Infrastructure & Systems",
    body: "Active Directory, Windows Server, DNS, email, backup, virtualization, migrations, cleanup, and hardening.",
    tags: ["Windows Server", "AD", "DNS", "Linux"],
  },
  {
    title: "Automation & DevOps",
    body: "PowerShell and Python automation, Docker and deployment cleanup, CI/CD workflows, and operational tooling.",
    tags: ["PowerShell", "Python", "Docker", "CI/CD"],
  },
  {
    title: "AI Enablement",
    body: "Practical AI workflow integration, coding-agent setup, internal tool acceleration, and documentation systems.",
    tags: ["Agents", "Workflows", "Tooling"],
  },
];
---

<BaseLayout title={site.brand} description={site.subhead}>
  <div class="flex items-center gap-2 text-sm text-slate-500">
    <span class="text-slate-400">●</span>
    <span>{site.domainLabel}</span>
  </div>

  <section class="mt-10">
    <h1 class="whitespace-pre-line text-5xl font-semibold tracking-tight text-slate-900 sm:text-6xl">
      {site.headline}
    </h1>
    <p class="mt-6 max-w-2xl text-base leading-7 text-slate-600">
      {site.subhead}
    </p>

    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href={site.links.contact}
        class="rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white no-underline hover:bg-slate-800"
      >
        Book a consultation
      </a>
      <a
        href={site.links.services}
        class="rounded-xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-900 no-underline hover:bg-slate-50"
      >
        See services
      </a>
    </div>
  </section>

  <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-2 border-y border-slate-100 py-4 text-sm text-slate-500">
    {site.trustItems.map((item) => <span>{item}</span>)}
  </div>

  <section class="mt-16">
    <h2 class="text-2xl font-semibold text-slate-900">Services</h2>
    <div class="mt-6 grid gap-6 lg:grid-cols-3">
      {services.map((svc) => (
        <Card title={svc.title} body={svc.body}>
          <div class="flex flex-wrap gap-2">
            {svc.tags.map((t) => <Tag label={t} />)}
          </div>
        </Card>
      ))}
    </div>
  </section>

  <section class="mt-16">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-semibold text-slate-900">How I work</h2>
        <span class="text-xs text-slate-500">simple, explicit, testable</span>
      </div>
      <ol class="mt-6 grid gap-3 text-sm text-slate-600">
        <li>1) Define scope</li>
        <li>2) Ship increments</li>
        <li>3) Add guardrails</li>
        <li>4) Document everything</li>
        <li>5) Hand-off</li>
      </ol>
      <p class="mt-6 text-sm text-slate-700">If it cannot be repeated, it is not done.</p>
    </div>
  </section>

  <section class="mt-16">
    <div class="flex items-center justify-between">
      <h2 class="text-2xl font-semibold text-slate-900">Featured work</h2>
      <span class="text-xs text-slate-500">anonymized, on purpose</span>
    </div>
    <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex items-start justify-between gap-6">
        <div>
          <h3 class="text-base font-semibold text-slate-900">
            High-volume Windows file transfer automation
          </h3>
          <p class="mt-2 text-sm text-slate-600">
            Moved large file sets reliably using an input list, with progress reporting and restartable execution.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <Tag label="Client" />
            <Tag label="PowerShell" />
            <Tag label="Windows Server" />
            <Tag label="File Ops" />
          </div>
        </div>
        <a
          href="/work"
          class="mt-1 text-sm font-semibold text-slate-700 no-underline hover:text-slate-900"
          title="View case studies"
        >
          ↗
        </a>
      </div>
    </div>
  </section>

  <section class="mt-16 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm text-center">
    <h2 class="text-xl font-semibold text-slate-900">
      Need a sharp operator, not another vague consultant?
    </h2>
    <p class="mx-auto mt-3 max-w-xl text-sm text-slate-600">
      Practical fixes, clean automation, and systems that are easier to run tomorrow than they are today.
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a
        href={site.links.contact}
        class="rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white no-underline hover:bg-slate-800"
      >
        Book a consultation
      </a>
      <a
        href={site.links.services}
        class="rounded-xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-900 no-underline hover:bg-slate-50"
      >
        See services
      </a>
    </div>
  </section>

  <footer class="mt-16 flex items-center justify-between border-t border-slate-200 py-8 text-sm text-slate-500">
    <span>© {new Date().getFullYear()} vertex_chaos</span>
    <div class="flex gap-6">
      <a class="no-underline hover:text-slate-900" href="/about">About</a>
      <a class="no-underline hover:text-slate-900" href="/privacy">Privacy</a>
    </div>
  </footer>
</BaseLayout>
