---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site, mailtoLink } from "@/config/site";
import { intro, tagline, services, processSteps } from "@/config/content";
import { getCollection } from "astro:content";

const work = (await getCollection("work")).slice(0, 3);
---

<BaseLayout
  title={`${site.name} | Automation & DevOps`}
  description="Automation, DevOps, CI/CD, IaC, PowerShell, Python, and infrastructure reliability."
>
  <section class="vc-container pt-14">
    <div class="vc-card p-8 md:p-10">
      <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
        <div class="space-y-4 md:max-w-2xl">
          <p class="vc-pill">Friendly technical. Public-safe. Deliverable-driven.</p>
          <h1 class="text-3xl font-semibold tracking-tight md:text-4xl">
            {intro.headline}
          </h1>
          <p class="text-base md:text-lg" style="color: var(--color-app-muted);">
            {intro.subhead}
          </p>

          <div class="flex flex-wrap gap-3 pt-2">
            <a class="vc-btn vc-btn-primary" href={mailtoLink}>Contact for quote</a>
            <a class="vc-btn" href="/work">View work</a>
            <a class="vc-btn" href="/resume">View resume</a>
          </div>

          <p class="pt-2 text-sm" style="color: var(--color-app-muted);">
            {tagline}
          </p>
        </div>

        <div class="grid gap-3 md:w-[260px]">
          {intro.proof.map((p) => (
            <div class="rounded-2xl border p-4" style="border-color: var(--color-app-border); background: color-mix(in oklab, white 2.5%, transparent);">
              <div class="text-xs" style="color: var(--color-app-muted);">{p.label}</div>
              <div class="text-base font-semibold">{p.value}</div>
            </div>
          ))}
          <div class="rounded-2xl border p-4" style="border-color: var(--color-app-border); background: color-mix(in oklab, white 2.5%, transparent);">
            <div class="text-xs" style="color: var(--color-app-muted);">Email</div>
            <a class="vc-link text-sm" href={mailtoLink}>{site.contactEmail}</a>
          </div>
        </div>
      </div>

      <div class="mt-8 grid gap-3 md:grid-cols-2">
        {intro.bullets.map((b) => (
          <div class="flex items-start gap-3 rounded-2xl border p-4" style="border-color: var(--color-app-border); background: color-mix(in oklab, white 2.5%, transparent);">
            <span aria-hidden="true" class="mt-1 inline-flex h-2.5 w-2.5 rounded-full" style="background: var(--color-vertex-500);"></span>
            <div class="text-sm" style="color: var(--color-app-muted);">{b}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="vc-container mt-14">
    <div class="flex items-end justify-between gap-6">
      <div class="space-y-2">
        <h2 class="text-xl font-semibold">Services</h2>
        <p class="text-sm" style="color: var(--color-app-muted);">
          Clear scope, predictable delivery, documentation included.
        </p>
      </div>
      <a class="vc-btn" href="/services">All services</a>
    </div>

    <div class="mt-6 grid gap-5 md:grid-cols-2">
      {services.map((s) => (
        <div class="vc-card p-6">
          <div class="flex items-start justify-between gap-4">
            <h3 class="text-base font-semibold">{s.title}</h3>
            <div class="flex flex-wrap gap-2 justify-end">
              {s.tags.slice(0, 2).map((t) => <span class="vc-pill">{t}</span>)}
            </div>
          </div>
          <p class="mt-2 text-sm" style="color: var(--color-app-muted);">{s.blurb}</p>
          <ul class="mt-4 space-y-2 text-sm" style="color: var(--color-app-muted);">
            {s.deliverables.slice(0, 3).map((d) => <li>• {d}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="vc-container mt-14">
    <h2 class="text-xl font-semibold">How I work</h2>
    <p class="mt-2 text-sm" style="color: var(--color-app-muted);">
      No drama. Just outcomes, constraints, milestones, and docs.
    </p>

    <div class="mt-6 grid gap-5 md:grid-cols-2">
      {processSteps.map((p, idx) => (
        <div class="vc-card p-6">
          <div class="flex items-center gap-3">
            <span class="vc-kbd">Step {idx + 1}</span>
            <h3 class="text-base font-semibold">{p.title}</h3>
          </div>
          <p class="mt-2 text-sm" style="color: var(--color-app-muted);">{p.text}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="vc-container mt-14">
    <div class="flex items-end justify-between gap-6">
      <div class="space-y-2">
        <h2 class="text-xl font-semibold">Selected work</h2>
        <p class="text-sm" style="color: var(--color-app-muted);">
          Public-safe summaries (no names, no identifiable details).
        </p>
      </div>
      <a class="vc-btn" href="/work">All work</a>
    </div>

    <div class="mt-6 grid gap-5 md:grid-cols-3">
      {work.map((w) => (
        <a href={`/work/${w.slug}`} class="vc-card block p-6">
          <h3 class="text-base font-semibold">{w.data.title}</h3>
          <p class="mt-2 text-sm" style="color: var(--color-app-muted);">{w.data.excerpt}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {w.data.stack.slice(0, 3).map((t) => <span class="vc-pill">{t}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="vc-container mt-14 pb-20">
    <div class="vc-card p-8 md:p-10">
      <h2 class="text-xl font-semibold">Want this kind of calm in your infrastructure?</h2>
      <p class="mt-2 text-sm" style="color: var(--color-app-muted);">
        Send context, constraints, and what “done” means. I’ll respond with a plan and clear deliverables.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="vc-btn vc-btn-primary" href={mailtoLink}>Contact for quote</a>
        <a class="vc-btn" href="/contact">What to send</a>
        <a class="vc-btn" href="/upwork">Upwork materials</a>
      </div>
    </div>
  </section>
</BaseLayout>
