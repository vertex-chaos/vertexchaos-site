---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Message received | vertex_chaos" description="Your message has been received.">
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <div class="text-5xl mb-6">✓</div>
    <h1 class="text-3xl font-bold tracking-tight text-slate-900">Message received</h1>
    <p class="mt-4 max-w-md text-slate-600">
      I will get back to you within 4 hours on U.S. business days with whether it fits a package or needs a custom scope.
    </p>
    <a href="/" class="mt-8 rounded-xl bg-slate-900 px-6 py-3 text-sm font-semibold text-white no-underline hover:bg-slate-800">
      Back to home
    </a>
  </div>
</BaseLayout>
